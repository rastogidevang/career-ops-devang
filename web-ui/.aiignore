# .aiignore — files AI agents should NOT load into context.
# Same syntax as .gitignore. Read before any agent-driven exploration.

# ── Vendored / generated ──────────────────────────────────────────────
node_modules/
package-lock.json
**/*.min.js
**/*.min.css
coverage/
dist/
build/

# ── Binary & visual artifacts (no useful tokens) ──────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.pdf
*.ico
*.woff
*.woff2
*.ttf
screenshots/
screen_*.png
public/screen_*.png

# ── Local-only state ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.log
.DS_Store
.cache/

# ── Parent-project user data that may sit next to web-ui (NEVER load) ─
# When this repo is dropped into career-ops/web-ui, the parent owns these.
# Loading them risks leaking a real user's CV, tracker, salary data.
../cv.md
../config/profile.yml
../article-digest.md
../data/applications.md
../data/follow-ups.md
../data/scan-history.tsv
../data/activity.jsonl
../jds/
../output/
../reports/
../interview-prep/

# ── Translated docs (open canonical English first; load locale on demand) ──
README.cn.md
README.es.md
README.ja.md
README.ko-KR.md
README.pt-BR.md
README.ru.md
README.zh-TW.md
CHANGELOG.es.md
CHANGELOG.ja.md
CHANGELOG.ko-KR.md
CHANGELOG.pt-BR.md
CHANGELOG.ru.md
CHANGELOG.zh-CN.md
CHANGELOG.zh-TW.md
docs/help/es.md
docs/help/ja.md
docs/help/ko-KR.md
docs/help/pt-BR.md
docs/help/ru.md
docs/help/zh-CN.md
docs/help/zh-TW.md

# ── Test fixtures with low information density ────────────────────────
tests/fixtures/

# ── GSD planning artifacts (loaded explicitly by gsd-* skills, not by default) ──
.planning/
