{
  "name": "@fighter90/career-ops-ui",
  "version": "1.69.2",
  "description": "Clean, docs-style web interface for the career-ops AI job-search pipeline — search, evaluate, deep-dive, apply, track every offer from a single browser tab.",
  "type": "module",
  "license": "MIT",
  "author": "Fighter90",
  "homepage": "https://github.com/Fighter90/career-ops-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fighter90/career-ops-ui.git"
  },
  "bugs": {
    "url": "https://github.com/Fighter90/career-ops-ui/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "bin/",
    "server/",
    "public/",
    "scripts/",
    "README*.md",
    "CHANGELOG*.md",
    "LICENSE"
  ],
  "keywords": [
    "career-ops",
    "job-search",
    "claude-code",
    "greenhouse",
    "ashby",
    "lever",
    "hh.ru",
    "habr-career",
    "ats",
    "express",
    "sse"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "server/index.mjs",
  "bin": {
    "career-ops-ui": "bin/career-ops-ui.sh",
    "career-ops-ui-start": "bin/start.sh"
  },
  "scripts": {
    "start": "node server/index.mjs",
    "dev": "node --watch server/index.mjs",
    "test": "node --test tests/*.test.mjs tests/acceptance/*.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage tests/*.test.mjs tests/acceptance/*.test.mjs",
    "test:e2e": "node tests/e2e.mjs",
    "test:e2e:full": "node tests/e2e-comprehensive.mjs",
    "test:e2e:browser": "node --test tests/playwright-smoke.mjs tests/playwright-full-cycle.mjs tests/playwright-forms.mjs tests/playwright-locale-sweep.mjs tests/playwright-theme-toggle-i18n.mjs",
    "audit:i18n": "node tools/i18n-audit.mjs",
    "test:ci": "npm test && node scripts/check-no-also-leftovers.mjs && node scripts/check-changelog-parity.mjs && node tools/i18n-audit.mjs",
    "import:trending": "node scripts/import-trending-companies.mjs",
    "capture:dashboards": "node scripts/capture-dashboard-screenshots.mjs",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "dependencies": {
    "express": "^4.22.2",
    "js-yaml": "^4.1.0",
    "multer": "^2.1.1"
  }
}
